# ============================================================================
# Suporte Inteligente CEFET/RJ — variáveis de ambiente
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env` e ajuste os valores. Nunca commite o `.env`.
# Em produção, configure via cofre de segredos (k8s, AWS SM, GH Secrets etc.).
# ============================================================================

# ───── Aplicação ─────
APP_NAME="Suporte Inteligente CEFET/RJ"
APP_ENV=development                 # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ───── Groq / Llama ─────
# Crie sua chave em: https://console.groq.com/keys
GROQ_API_KEY=cole_sua_chave_aqui
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT_SECONDS=30

# ───── Sessões ─────
SESSION_TTL_SECONDS=7200            # 2h de inatividade encerra a sessão
SESSION_MAX_MESSAGES=40             # máximo de mensagens preservadas por sessão

# ───── Segurança ─────
# Token compartilhado entre o frontend (TanStack Start) e o backend FastAPI.
# Vazio = autenticação desabilitada (apenas para desenvolvimento local).
#
# ⚠️  IMPORTANTE: o valor de API_TOKEN (backend) e CHATBOT_API_KEY (frontend, ver
# mais abaixo) PRECISA ser EXATAMENTE o mesmo. O backend valida o que o frontend
# envia no header `X-API-Token`. Se ficarem diferentes (ou um vazio e o outro
# preenchido), todas as chamadas ao /chat retornam 401 Unauthorized.
#
# Gere com:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=200
MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_MESSAGES=20

# Origens permitidas (CORS). Separadas por vírgula.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ───── Logs ─────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console                  # console (dev) | json (prod)

# ============================================================================
# Variáveis lidas pelo FRONTEND (TanStack Start — server-only)
# ----------------------------------------------------------------------------
# A server function `sendChatMessage` lê esses valores. NÃO use prefixo VITE_
# para não vazá-los ao navegador.
# ============================================================================
CHATBOT_API_URL=http://localhost:8000/chat
# ⚠️  Deve ser EXATAMENTE igual a API_TOKEN (acima). Se o backend não tiver
# token configurado, deixe ambos vazios.
CHATBOT_API_KEY=
CHATBOT_TIMEOUT_MS=30000
